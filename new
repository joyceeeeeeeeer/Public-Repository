app:
  description: KYC Middle Platform for Joyce
  icon: 🤖
  icon_background: '#FFEAD5'
  mode: workflow
  name: KYC_Middle_Platform_v2
version: 1.1.0  # 关键点：根据你找的博文，必须声明版本号
workflow:
  features:
    file_upload:
      enabled: false
  nodes:
    - data:
        title: Start
        type: start
        variables:
          - label: tenant_id
            type: select
            options: [Main_Site, EU_Site]
            variable: tenant_id
            required: true
      id: 'node_1'
      position: {x: 80, y: 200}
      type: custom
    - data:
        code_language: python3
        code: |
          def main(tenant_id: str) -> dict:
              return {"is_reuse": "True" if tenant_id == "Main_Site" else "False"}
        title: Reuse_Logic
        type: code
      id: 'node_2'
      position: {x: 350, y: 200}
      type: custom
