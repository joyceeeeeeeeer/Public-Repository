app:
  description: KYC Middle Platform (Legacy Version)
  icon: 🤖
  icon_background: '#FFEAD5'
  mode: workflow
  name: KYC_Middle_Platform_v06
version: 0.6.0  # 必须匹配你系统提示的版本号
workflow:
  nodes:
    - data:
        title: Start
        type: start
        variables:
          - label: tenant_id
            type: text-input
            variable: tenant_id
            required: true
      id: 'start_node'
      type: custom
    - data:
        code_language: python3
        code: |
          def main(tenant_id: str) -> dict:
              # 0.6.0 版本的简单逻辑
              return {"is_reuse": "True" if tenant_id == "Main_Site" else "False"}
        title: Reuse_Logic
        type: code
      id: 'logic_node'
      type: custom
