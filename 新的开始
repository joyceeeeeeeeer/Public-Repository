version: 1.0.0
module: flow_schemes
description: >
  KYC 中台的“流程方案模块”配置。
  重点：场景标准化、流程编排、表单复用、策略规则、节点链路记录与回溯。

tenants:
  - id: global
    name: Global Ops
    licenses: [crypto_exchange, stock_broker]
  - id: eu
    name: EU Region
    licenses: [crypto_exchange]
  - id: jp
    name: Japan Region
    licenses: [crypto_exchange]

business_modes:
  - id: crypto_exchange
    name: 虚拟币交易所
  - id: stock_broker
    name: 股票交易
  - id: payment
    name: 支付业务

user_roles:
  - id: C
    name: 个人用户
  - id: B
    name: 企业用户

scenarios:
  - id: identity_c_onboarding
    name: C 端开户 Onboarding
    tenant_ids: [global, eu]
    business_mode_ids: [crypto_exchange, stock_broker]
    user_role_id: C
    atomic_label: onboarding
    description: >
      C 端用户首次开户的 KYC 场景。根据牌照、国家、业务模式路由到不同流程方案。
    enabled: true

  - id: identity_c_reverification
    name: C 端风险复核 / 复核 KYC
    tenant_ids: [global]
    business_mode_ids: [crypto_exchange]
    user_role_id: C
    atomic_label: risk_reverification
    description: >
      针对存量用户的合规复核 / 风险复核场景。

case_definition:
  id_rule: >
    CASE_ID = {tenant}-{business_mode}-{scenario}-{date}-{sequence}
  uniqueness_scope:
    - tenant_id
    - business_mode_id
    - scenario_id
    - user_id
  reuse_policy:
    same_tenant:
      allow_reuse: true
      reuse_dimensions:
        - identity_document
        - face_biometric
        - address_proof
    cross_tenant:
      allow_reuse: true
      require_consent: true
      consent_record_type: data_sharing_agreement

flows:
  - id: global_c_onboarding_standard
    name: Global C 端标准开户流程
    tenant_id: global
    business_mode_id: crypto_exchange
    scenario_id: identity_c_onboarding
    version: "1.0.0"
    status: active

    meta:
      max_steps: 16
      created_by: product_owner_x
      created_at: "2025-12-20T10:00:00+08:00"
      last_updated_at: "2026-01-10T11:30:00+08:00"

    stages:
      - id: collect
        name: 信息收集
        order: 1
      - id: auto_review
        name: 自动审核
        order: 2
      - id: manual_review
        name: 人工审核
        order: 3
      - id: disposition
        name: 处置 / 通知
        order: 4

    nodes:
      - id: S1_collect_basic
        stage_id: collect
        name: 采集基础身份信息
        description: 收集姓名、生日、国籍、税务居民等基础信息。
        type: 收集节点
        entry_condition:
          expression: "case.is_new == true"
        steps:
          - id: S1_1_basic_profile_form
            type: form
            form_id: form_basic_profile_v1
            order: 1
          - id: S1_2_tax_info_form
            type: form
            form_id: form_tax_info_v1
            order: 2

      - id: S2_collect_documents
        stage_id: collect
        name: 采集证件信息
        type: 收集节点
        entry_condition:
          expression: "user.country in ['US','EU','JP']"
        steps:
          - id: S2_1_doc_upload
            type: form
            form_id: form_id_document_v2
            order: 1

      - id: S3_vendor_checks
        stage_id: auto_review
        name: 三方风控 / 黑名单 / KYC 调用
        type: 认证节点
        steps:
          - id: S3_1_vendor_kyc
            type: vendor_call
            vendor_id: vendor_kyc_x
            api: /verify
            error_mapping_table_id: vendor_kyc_x_error_codes_v1
          - id: S3_2_vendor_risk
            type: vendor_call
            vendor_id: vendor_risk_y
            api: /score
            error_mapping_table_id: vendor_risk_y_error_codes_v1

      - id: S4_cra_rules
        stage_id: auto_review
        name: CRA 风险规则判断
        type: 处理节点
        steps:
          - id: S4_1_cra_decision
            type: rule_set
            rule_table_id: cra_rules_v1
            outputs:
              - risk_level
              - need_manual_review

      - id: S13_manual_review
        stage_id: manual_review
        name: 人工审核节点
        type: 人工节点
        steps:
          - id: S13_1_manual_panel
            type: manual_review_ui
            ui_id: audit_workspace_v1

      - id: S17_notify_user
        stage_id: disposition
        name: 通知用户结果
        type: 处理节点
        steps:
          - id: S17_1_send_notification
            type: notification
            template_ids:
              success: tpl_kyc_pass_v1
              reject: tpl_kyc_reject_v1
              retry: tpl_kyc_retry_v1

    transitions:
      - from: S1_collect_basic
        to: S2_collect_documents
        type: normal
        condition: "true"
      - from: S2_collect_documents
        to: S3_vendor_checks
        type: normal
        condition: "true"
      - from: S4_cra_rules
        to: S13_manual_review
        type: jump
        condition: "output.risk_level in ['HIGH','VERY_HIGH']"
      - from: S4_cra_rules
        to: S17_notify_user
        type: normal
        condition: "output.risk_level in ['LOW','MEDIUM']"

forms:
  - id: form_basic_profile_v1
    name: 基础信息表单
    description: 通用 C 端基础信息表单，可跨场景 / 流程复用。
    fields:
      - key: first_name
        label: 名
        type: string
        required: true
      - key: last_name
        label: 姓
        type: string
        required: true
      - key: country
        label: 国籍
        type: country_code
        required: true
      - key: tax_residency
        label: 税务居民国
        type: country_code[]
        required: true

  - id: form_id_document_v2
    name: 证件信息表单（V2）
    description: 通用证件表单。不同业务模式 / 国家可通过策略配置必填字段。
    fields:
      - key: doc_type
        label: 证件类型
        type: enum
        metadata_ref: metadata.enums.doc_type
      - key: doc_number
        label: 证件号码
        type: string
      - key: doc_expiry
        label: 证件有效期
        type: date

rule_tables:
  - id: cra_rules_v1
    name: CRA 风险评分规则表
    type: DMN
    description: >
      根据国别、业务模式、交易额度等，输出 risk_level 与是否需要人工审核。
    inputs:
      - user_country
      - business_mode_id
      - kyc_vendor_result
      - historical_risk_flags
    outputs:
      - risk_level
      - need_manual_review

  - id: id_doc_match_rules_v1
    name: 证件匹配 / 比对规则
    type: script
    description: >
      控制证件比对（OCR vs 用户输入、OCR vs vendor）的规则，避免黑盒。
    inputs:
      - ocr_result
      - user_input
      - vendor_result
    outputs:
      - match_result
      - mismatch_reason_code

vendor_error_mappings:
  - id: vendor_kyc_x_error_codes_v1
    vendor_id: vendor_kyc_x
    description: Vendor KYC X 的 error code → 平台统一错误码映射表
    items:
      - vendor_code: "E_DOC_EXPIRED"
        platform_error_tag: "id_doc_expired"
        severity: high
      - vendor_code: "E_FACE_MISMATCH"
        platform_error_tag: "face_mismatch"
        severity: high

  - id: vendor_risk_y_error_codes_v1
    vendor_id: vendor_risk_y
    description: Vendor Risk Y 的 error code → 平台统一错误码映射表
    items:
      - vendor_code: "E_SANCTION_HIT"
        platform_error_tag: "sanction_hit"
        severity: critical

observability:
  case_timeline_enabled: true
  record_granularity: step
  metrics:
    - id: vendor_pass_rate
      name: Vendor 通过率
      dimensions: [vendor_id, scenario_id, flow_id]
    - id: cra_risk_distribution
      name: CRA 风险等级分布
      dimensions: [tenant_id, business_mode_id, scenario_id]
    - id: auto_vs_manual_ratio
      name: 自动通过 vs 人工审核占比
      dimensions: [tenant_id, scenario_id]
