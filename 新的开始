app:
  description: 'KYC 中台标准化编排 - 评审演示版'
  icon: 🤖
  icon_background: '#FFEAD5'
  mode: workflow
  name: KYC_Middle_Platform
  use_icon_as_answer_icon: false
kind: app
version: 0.6.0
workflow:
  features:
    file_upload:
      enabled: false
    retriever_resource:
      enabled: true
  graph:
    edges:
      - data: {sourceType: start, targetType: if-else}
        id: edge_start_to_if
        source: 'node_start'
        target: 'node_router'
      - data: {sourceType: if-else, targetType: code}
        id: edge_if_true_to_code
        source: 'node_router'
        sourceHandle: 'true'
        target: 'node_logic'
    nodes:
      - data:
          title: User Input
          type: start
          variables:
            - label: tenant_id
              type: text-input
              variable: tenant_id
              required: true
            - label: biz_mode
              type: text-input
              variable: biz_mode
              required: true
        id: 'node_start'
        position: {x: 80, y: 282}
        type: custom
        width: 242
      - data:
          cases:
            - case_id: 'true'
              conditions:
                - comparison: equal
                  variable: [node_start, tenant_id]
                  value: 'Main_Site'
          title: 路由分发 (Router)
          type: if-else
        id: 'node_router'
        position: {x: 360, y: 279}
        type: custom
        width: 242
      - data:
          code_language: python3
          code: |
            def main(tenant_id: str, biz_mode: str) -> dict:
                # 对应 Leader 要求的：场景标识决定流程方案
                is_reuse = "True" if tenant_id == "Main_Site" and biz_mode == "Crypto" else "False"
                return {
                    "strategy": "REUSE_PATH" if is_reuse == "True" else "FULL_PATH",
                    "decision": "SKIP_STEP_1" if is_reuse == "True" else "COLLECT_ALL"
                }
          title: 规则策略集 (CRA)
          type: code
        id: 'node_logic'
        position: {x: 640, y: 279}
        type: custom
        width: 242
